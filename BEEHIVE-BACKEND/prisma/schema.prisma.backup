generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model users {
  id            String    @id
  email         String    @unique
  password      String
  name          String
  role          user_role @default(CUSTOMER)
  phone         String?
  loyaltyPoints Int       @default(0)
  cardNumber    String?   @unique
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime
  lastLoginAt   DateTime?

  @@index([email])
  @@index([role])
  @@index([cardNumber])
}

model categories {
  id          String       @id @db.VarChar(255)
  name        String       @unique @db.VarChar(255)
  displayName String       @db.VarChar(255)
  description String?
  sortOrder   Int?         @default(0)
  isActive    Boolean?     @default(true)
  createdAt   DateTime?    @default(now()) @db.Timestamp(6)
  updatedAt   DateTime?    @default(now()) @db.Timestamp(6)
  menu_items  menu_items[]

  @@index([name])
  @@index([isActive], map: "categories_isactive_idx")
  @@index([sortOrder], map: "categories_sortorder_idx")
}

model menu_items {
  id                    String                  @id
  name                  String
  price                 Float
  cost                  Float?                  @default(0)
  image                 String?
  description           String?
  available             Boolean                 @default(true)
  featured              Boolean                 @default(false)
  prepTime              Int?                    @default(5)
  nutrients             String?
  moodBenefits          String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime
  categoryId            String                  @db.VarChar(255)
  // NEW: Item type for filtering (BASE items only in mood system)
  itemType              menu_item_type          @default(BASE)
  // NEW: For ADDON items - whether to also show in regular menu (false = only as add-on)
  showInMenu            Boolean                 @default(false)
  menu_item_ingredients menu_item_ingredients[]
  menu_item_mood_stats  menu_item_mood_stats[]
  category              categories              @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "menu_items_categoryid_fkey")
  order_items           order_items[]
  // NEW: Variants for this item (e.g., Small/Medium/Large)
  variants              menu_item_variants[]
  // NEW: Add-ons allowed for this base item
  allowed_addons        menu_item_addons[]      @relation("BaseItemAddons")
  // NEW: When this item IS an add-on, which base items allow it
  addon_for_items       menu_item_addons[]      @relation("AddonItem")

  @@index([available])
  @@index([featured])
  @@index([categoryId], map: "menu_items_categoryid_idx")
  @@index([itemType])
}

model order_items {
  id         String            @id
  orderId    String
  menuItemId String
  quantity   Int
  price      Float
  subtotal   Float
  status     order_item_status @default(PREPARING)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime
  // NEW: Selected variant for this order item (null = default/no variant)
  variantId  String?
  // NEW: Notes/special instructions for this item
  notes      String?
  menu_items menu_items        @relation(fields: [menuItemId], references: [id])
  orders     orders            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  // NEW: Selected variant relation
  variant    menu_item_variants? @relation(fields: [variantId], references: [id])
  // NEW: Add-ons selected for this order item
  order_item_addons order_item_addons[]

  @@index([menuItemId])
  @@index([orderId])
  @@index([status])
  @@index([variantId])
}

model orders {
  id                String         @id
  orderNumber       String         @unique
  customerName      String?
  tableNumber       String?
  status            order_status   @default(PENDING)
  subtotal          Float
  tax               Float
  totalAmount       Float
  paymentMethod     String?
  paymentStatus     payment_status @default(UNPAID)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime
  completedAt       DateTime?
  orderType         order_type     @default(DINE_IN)
  moodContext       String?
  linkedOrderId     String?
  createdBy         String?
  moodFeedbackGiven Boolean        @default(false)
  deviceId          String?
  processedBy       String?
  authorizedBy      String?
  discountAmount    Float          @default(0)
  notes             String?
  paidAt            DateTime?
  cashReceived      Float?
  changeAmount      Float?
  deliveryFee       Float          @default(0)
  serviceFee        Float          @default(0)
  order_items       order_items[]

  @@index([createdAt])
  @@index([status])
  @@index([linkedOrderId])
  @@index([createdBy])
  @@index([deviceId])
  @@index([processedBy])
  @@index([paymentStatus])
}

model inventory_items {
  id                    String                  @id
  name                  String
  category              inventory_category
  currentStock          Float
  minStock              Float
  maxStock              Float
  unit                  String
  costPerUnit           Float
  supplier              String
  status                inventory_status        @default(IN_STOCK)
  lastRestocked         DateTime                @default(now())
  createdAt             DateTime                @default(now())
  updatedAt             DateTime
  restockFrequencyDays  Int?                    @default(7)
  menu_item_ingredients menu_item_ingredients[]
  stock_transactions    stock_transactions[]

  @@index([category])
  @@index([status])
}

model expenses {
  id          String            @id
  category    expense_category
  date        DateTime
  amount      Float
  description String
  frequency   expense_frequency
  attachment  String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime

  @@index([date])
  @@index([category])
  @@index([frequency])
}

model stock_transactions {
  id              String                   @id
  inventoryItemId String
  type            stock_transaction_type
  reason          stock_transaction_reason
  quantity        Float
  referenceId     String?
  userId          String?
  notes           String?
  createdAt       DateTime                 @default(now())
  inventory_item  inventory_items          @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@index([inventoryItemId])
  @@index([type])
  @@index([reason])
  @@index([referenceId])
  @@index([createdAt])
}

model menu_item_ingredients {
  id              String          @id
  menuItemId      String
  inventoryItemId String
  quantity        Float
  createdAt       DateTime        @default(now())
  updatedAt       DateTime
  inventory_item  inventory_items @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  menu_item       menu_items      @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, inventoryItemId])
  @@index([menuItemId])
  @@index([inventoryItemId])
}

model mood_settings {
  id                      String    @id
  mood                    mood_type @unique
  emoji                   String
  label                   String
  color                   String
  description             String
  supportMessage          String?
  scientificExplanation   String?
  beneficialNutrients     String?
  preferredCategories     String?
  excludeCategories       String?
  preferredCategoryPoints Int       @default(10)
  isActive                Boolean   @default(true)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime

  @@index([mood])
  @@index([isActive])
}

model mood_feedback_config {
  id                      String   @id @default("default")
  baselineThreshold       Int      @default(50)
  feedbackEnabled         Boolean  @default(false)
  autoEnableFeedback      Boolean  @default(true)
  orderRateWeight         Float    @default(0.6)
  feedbackRateWeight      Float    @default(0.4)
  moodBenefitsWeight      Int      @default(20)
  preferredCategoryWeight Int      @default(10)
  featuredItemWeight      Int      @default(5)
  priceRangeWeight        Int      @default(5)
  historicalDataWeight    Int      @default(15)
  timeOfDayWeight         Int      @default(5)
  showMoodReflection      Boolean  @default(true)
  reflectionDelayMinutes  Int      @default(15)
  createdAt               DateTime @default(now())
  updatedAt               DateTime
  afternoonCategories     String   @default("[]")
  afternoonEndHour        Int      @default(18)
  eveningCategories       String   @default("[\"HOT_DRINKS\",\"PLATTER\"]")
  morningCategories       String   @default("[\"HOT_DRINKS\"]")
  morningEndHour          Int      @default(12)
  morningStartHour        Int      @default(6)
  explorationBonusWeight  Int      @default(8)
  minimumOrdersThreshold  Int      @default(10)
  excludedCategoryPenalty Int      @default(0)
  day0PositionShuffle     Boolean  @default(true)
  showRankingNumbers      Boolean  @default(false)
}

model mood_order_stats {
  id              String    @id
  mood            mood_type @unique
  totalShown      Int       @default(0)
  totalOrdered    Int       @default(0)
  feedbackCount   Int       @default(0)
  moodImproved    Int       @default(0)
  moodSame        Int       @default(0)
  moodWorse       Int       @default(0)
  baselineReached Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime

  @@index([mood])
  @@index([baselineReached])
}

model menu_item_mood_stats {
  id            String     @id
  menuItemId    String
  mood          mood_type
  timesShown    Int        @default(0)
  timesOrdered  Int        @default(0)
  feedbackCount Int        @default(0)
  moodImproved  Int        @default(0)
  moodSame      Int        @default(0)
  moodWorse     Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime
  menu_items    menu_items @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, mood])
  @@index([menuItemId])
  @@index([mood])
}

// ============================================================================
// ADD-ONS & VARIANTS SUPPORT (Additive - does not break existing functionality)
// ============================================================================

// Variants for a menu item (e.g., Small/Medium/Large, Hot/Iced)
// Only affects price via priceDelta, base item ingredients always deduct
model menu_item_variants {
  id          String        @id
  menuItemId  String
  name        String        // e.g., "Small", "Medium", "Large", "Hot", "Iced"
  priceDelta  Float         @default(0) // Price adjustment (+/- from base price)
  isDefault   Boolean       @default(false)
  sortOrder   Int           @default(0)
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime
  menu_item   menu_items    @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  order_items order_items[]

  @@unique([menuItemId, name])
  @@index([menuItemId])
  @@index([isActive])
}

// Links base menu items to their allowed add-ons
// Add-ons are themselves menu_items with itemType = ADDON
model menu_item_addons {
  id           String     @id
  baseItemId   String     // The base menu item
  addonItemId  String     // The add-on menu item (must have itemType = ADDON)
  maxQuantity  Int        @default(5) // Max quantity of this add-on per order item
  sortOrder    Int        @default(0)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime
  base_item    menu_items @relation("BaseItemAddons", fields: [baseItemId], references: [id], onDelete: Cascade)
  addon_item   menu_items @relation("AddonItem", fields: [addonItemId], references: [id], onDelete: Cascade)

  @@unique([baseItemId, addonItemId])
  @@index([baseItemId])
  @@index([addonItemId])
  @@index([isActive])
}

// Stores selected add-ons for each order item
// Allows quantity tracking per add-on (e.g., 2x extra egg)
model order_item_addons {
  id          String      @id
  orderItemId String
  addonItemId String      // References the add-on menu_item
  quantity    Int         @default(1)
  unitPrice   Float       // Price at time of order (add-on's menu_item.price)
  subtotal    Float       // quantity * unitPrice
  createdAt   DateTime    @default(now())
  order_item  order_items @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@unique([orderItemId, addonItemId])
  @@index([orderItemId])
  @@index([addonItemId])
}

// ============================================================================

enum order_type {
  DINE_IN
  TAKEOUT
  DELIVERY
}

enum order_status {
  PENDING
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum payment_status {
  UNPAID
  PAID
  REFUNDED
  COMPLIMENTARY
  WRITTEN_OFF
  VOIDED
}

enum user_role {
  CUSTOMER
  CASHIER
  COOK
  MANAGER
  ADMIN
}

enum inventory_category {
  INGREDIENTS
  BEVERAGES
  PACKAGING
  SUPPLIES
}

enum inventory_status {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
}

enum expense_category {
  RENT_LEASE
  UTILITIES
  ADMINISTRATIVE_SALARIES
  SOFTWARE_SUBSCRIPTIONS
  MAINTENANCE
  OTHER
}

enum expense_frequency {
  ONE_TIME
  MONTHLY
  QUARTERLY
  ANNUAL
}

enum stock_transaction_type {
  IN
  OUT
}

enum stock_transaction_reason {
  PURCHASE
  ORDER
  WASTE
  ADJUSTMENT
  RECONCILIATION
  VOID
}

enum mood_type {
  HAPPY
  ENERGETIC
  RELAXED
  EXCITED
  TIRED
  STRESSED
  ANXIOUS
  SAD
  DEPRESSED
  ANGRY
}

enum order_item_status {
  PREPARING
  COMPLETED
  VOIDED
}

// NEW: Menu item type for filtering add-ons from main menu/mood system
enum menu_item_type {
  BASE      // Regular menu items - appear in browsing, mood recommendations
  ADDON     // Add-ons (extra rice, egg) - only selectable after base item chosen
  DRINK     // Drinks - appear in browsing, may have add-ons (espresso shot)
}
