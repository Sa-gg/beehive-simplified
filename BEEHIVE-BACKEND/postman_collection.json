{
  "info": {
    "name": "BEEHIVE Menu Items API",
    "description": "Complete API collection for BEEHIVE Restaurant Menu Management System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Menu Items",
      "item": [
        {
          "name": "Get All Menu Items",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:3000/api/menu-items",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "menu-items"]
            }
          }
        },
        {
          "name": "Get All Menu Items (Filtered)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:3000/api/menu-items?category=PIZZA&available=true",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "menu-items"],
              "query": [
                {
                  "key": "category",
                  "value": "PIZZA",
                  "description": "Filter by category: PIZZA, APPETIZER, HOT_DRINKS, COLD_DRINKS, SMOOTHIE, PLATTER, SAVERS, VALUE_MEAL"
                },
                {
                  "key": "available",
                  "value": "true",
                  "description": "Filter by availability"
                },
                {
                  "key": "featured",
                  "value": "true",
                  "description": "Filter by featured status",
                  "disabled": true
                },
                {
                  "key": "search",
                  "value": "burger",
                  "description": "Search in name and description",
                  "disabled": true
                }
              ]
            }
          }
        },
        {
          "name": "Get Menu Item by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:3000/api/menu-items/:id",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "menu-items", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "your-menu-item-id-here",
                  "description": "Menu item UUID"
                }
              ]
            }
          }
        },
        {
          "name": "Create Menu Item",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Bacon Pepperoni Pizza\",\n  \"category\": \"PIZZA\",\n  \"price\": 299,\n  \"cost\": 180,\n  \"image\": \"/uploads/menu-images/pizza.jpg\",\n  \"description\": \"Classic pizza with bacon and pepperoni toppings\",\n  \"available\": true,\n  \"featured\": true,\n  \"prepTime\": 15\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/menu-items",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "menu-items"]
            }
          }
        },
